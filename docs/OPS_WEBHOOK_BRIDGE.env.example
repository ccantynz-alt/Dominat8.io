# ops-webhook-bridge Environment Variables

# Required: GitHub Personal Access Token with repo and workflow permissions
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_github_token_here

# Optional: Repository in format owner/repo (defaults to ccantynz-alt/Dominat8.io)
# GITHUB_REPOSITORY=ccantynz-alt/Dominat8.io

# Recommended: Secret for HMAC signature verification
# Generate a strong random secret: openssl rand -hex 32
OPS_WEBHOOK_SECRET=your_webhook_secret_here
