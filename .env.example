# ─────────────────────────────────────────────────────────────────────────────
# Dominat8.io — Environment Variables
#
# You need these in one or both places, depending on what you're doing:
#
#   LOCAL (run on your machine with "npm run dev"):
#     Paste into a file named .env.local in this project folder (same folder as
#     package.json). Create it by copying this file: copy .env.example .env.local
#     Then replace the placeholder values below with your real keys.
#
#   LIVE WEBSITE (e.g. dominat8.io on Vercel):
#     Paste in Vercel: open your project → Settings → Environment Variables.
#     Add each variable name (e.g. OPENAI_API_KEY) and its value. Redeploy after
#     adding or changing variables.
#
# If your site is already working online, the keys are probably already set in
# Vercel. You only need .env.local if you want to run the app locally.
#
# Minimum to run Builder + Generate: OpenAI + Clerk. Rest optional.
# ─────────────────────────────────────────────────────────────────────────────

# ── OpenAI (required for "Generate Site") ────────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Clerk (required for auth / user accounts) ─────────────────────────────────
# Create a project at: https://dashboard.clerk.com
# Set allowed redirect URLs: https://yourdomain.com/sign-in, /sign-up
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect paths (leave as-is unless you change the page routes)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ── Stripe (required for payments) ────────────────────────────────────────────
# Get keys at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook secret — from: https://dashboard.stripe.com/webhooks
# Point your webhook to: https://yourdomain.com/api/stripe/webhook
# Events to listen for: checkout.session.completed, customer.subscription.updated,
#                        customer.subscription.deleted, invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create recurring prices in Stripe Dashboard
# Product → Add price → Recurring → Monthly
STRIPE_STARTER_PRICE_ID=price_...   # $9/mo
STRIPE_PRO_PRICE_ID=price_...       # $29/mo
STRIPE_AGENCY_PRICE_ID=price_...    # $99/mo

# ── Vercel KV (optional: plan storage and usage limits) ──────────────────────
# Without these, generation still works; usage/limits are skipped.
# Create at: https://vercel.com/storage/kv — then: vercel env pull .env.local
KV_REST_API_URL=https://...
KV_REST_API_TOKEN=...

# ── Vercel Blob (optional: save and share generated site links) ────────────────
# Create a Blob store at: https://vercel.com/storage/blob
BLOB_READ_WRITE_TOKEN=vercel_blob_...

# ── App URL (used for Stripe redirect URLs) ────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://dominat8.io

# ── Optional ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_D8_TV=1
