# ─────────────────────────────────────────────────────────────────────────────
# Dominat8.io — Required Environment Variables
# Copy this file to .env.local and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── OpenAI (required for website generation) ──────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Clerk (required for auth / user accounts) ─────────────────────────────────
# Create a project at: https://dashboard.clerk.com
# Set allowed redirect URLs: https://yourdomain.com/sign-in, /sign-up
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect paths (leave as-is unless you change the page routes)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ── Stripe (required for payments) ────────────────────────────────────────────
# Get keys at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook secret — from: https://dashboard.stripe.com/webhooks
# Point your webhook to: https://yourdomain.com/api/stripe/webhook
# Events to listen for: checkout.session.completed, customer.subscription.updated,
#                        customer.subscription.deleted, invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create recurring prices in Stripe Dashboard
# Product → Add price → Recurring → Monthly
STRIPE_STARTER_PRICE_ID=price_...   # $9/mo
STRIPE_PRO_PRICE_ID=price_...       # $29/mo
STRIPE_AGENCY_PRICE_ID=price_...    # $99/mo

# ── Vercel KV (required for plan storage and usage tracking) ──────────────────
# Create a KV database at: https://vercel.com/storage/kv
# Then run: vercel env pull .env.local
KV_REST_API_URL=https://...upstash.io
KV_REST_API_TOKEN=...

# ── Vercel Blob (required for site sharing / save links) ──────────────────────
# Create a Blob store at: https://vercel.com/storage/blob
BLOB_READ_WRITE_TOKEN=vercel_blob_...

# ── App URL (used for Stripe redirect URLs) ────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# ── Optional ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_D8_TV=0
