# ─────────────────────────────────────────────────────────────────────────────
# Dominat8.io — Required Environment Variables
# Copy this file to .env.local and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Anthropic (preferred — powers website generation + all agents via Claude) ──
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI (fallback — used only when ANTHROPIC_API_KEY is absent) ────────────
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Clerk (required for auth / user accounts) ─────────────────────────────────
# Create a project at: https://dashboard.clerk.com
# Set allowed redirect URLs: https://yourdomain.com/sign-in, /sign-up
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect paths — send users to /build after sign in/up
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/build
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/build

# ── Stripe (required for payments) ────────────────────────────────────────────
# Get keys at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook secret — from: https://dashboard.stripe.com/webhooks
# Point your webhook to: https://yourdomain.com/api/stripe/webhook
# Events to enable: checkout.session.completed, customer.subscription.updated,
#                   customer.subscription.deleted, invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create recurring prices in Stripe Dashboard:
#   Stripe Dashboard → Products → Add product → Add price → Recurring → Monthly
STRIPE_STARTER_PRICE_ID=price_...   # $9/mo
STRIPE_PRO_PRICE_ID=price_...       # $29/mo
STRIPE_AGENCY_PRICE_ID=price_...    # $99/mo

# ── Vercel KV (required for plan storage and usage tracking) ──────────────────
# Create at: https://vercel.com/storage/kv  → then run: vercel env pull .env.local
KV_REST_API_URL=https://...upstash.io
KV_REST_API_TOKEN=...

# ── Vercel Blob (required for site sharing / save links) ──────────────────────
# Create at: https://vercel.com/storage/blob
BLOB_READ_WRITE_TOKEN=vercel_blob_...

# ── App URL (used for Stripe redirect URLs) ────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://dominat8.io

# ── Admin access ───────────────────────────────────────────────────────────────
# Comma-separated Clerk user IDs that bypass ALL credit limits and plan gates.
# Find your user ID in Clerk Dashboard → Users → click your user → copy "User ID"
ADMIN_USER_IDS=user_xxxxxxxxxxxxx,user_yyy

# ── Staging / Preview Environment ─────────────────────────────────────────────
# Set NEXT_PUBLIC_D8_ENV=staging on your Vercel staging project to:
#   1. Show the staging banner
#   2. Use separate Clerk keys (create a second Clerk project for staging)
# IMPORTANT: Use DIFFERENT Clerk keys for staging to avoid shared auth sessions!
# NEXT_PUBLIC_D8_ENV=staging

# ── Optional ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_D8_TV=0
