{
  "name": "my-saas-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint .",
    "typecheck": "tsc --noEmit",
    "guard:protected": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/guard-protected-paths.ps1",
    "ci:build": "npm run build",
    "ci:protected": "node scripts/protected-paths-check.mjs",
    "heal": "node scripts/heal.mjs",
    "heal:build": "node scripts/heal.mjs && npm run build",
    "finish-build": "node scripts/finish-build.mjs",
    "finish-build:no-lint": "node scripts/finish-build.mjs --skip-lint",
    "overnight": "node scripts/overnight-run.mjs",
    "finish:1h": "node scripts/run-one-hour.mjs",
    "keep-build": "node scripts/keep-build-moving.mjs",
    "keep-build:loop": "node scripts/keep-build-moving.mjs --loop",
    "finish:overnight": "node scripts/run-overnight-finish.mjs",
    "auto-improve": "node scripts/auto-improve.mjs"
  },
  "dependencies": {
    "@clerk/nextjs": "^5.7.5",
    "@react-three/drei": "^10.0.0",
    "@react-three/fiber": "^9.0.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^25.2.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vercel/blob": "^2.0.1",
    "@vercel/kv": "^2.0.0",
    "adm-zip": "^0.5.10",
    "autoprefixer": "^10.4.24",
    "framer-motion": "^12.34.3",
    "next": "^16.1.6",
    "openai": "^4.0.0",
    "postcss": "^8.5.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "stripe": "^14.0.0",
    "three": "^0.183.1",
    "typescript": "^5.9.3",
    "vanta": "^0.5.24",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/three": "^0.183.1",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.1.6",
    "tailwindcss": "^4.1.18"
  },
  "engines": {
    "node": "20.x"
  }
}
